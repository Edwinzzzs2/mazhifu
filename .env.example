# 站点外部访问地址，用于生成支付回调、支付返回和订单链接；本地开发用 localhost，线上填 https 域名。
APP_URL=http://localhost:3000
# 仅当反向代理会覆盖 x-forwarded-* / x-real-ip 时开启；用于生成可信来源和按 IP 限流。
TRUST_PROXY=false
# APP_URL 缺失时仅供本地开发校验 Host，多个值用逗号分隔；生产环境仍强制要求 APP_URL。
ALLOWED_HOSTS=

# 码支付商户 ID。
MAPAY_PID=
# 码支付商户密钥，用于请求签名和回调验签，不能泄露。
MAPAY_KEY=
# 码支付提交付款页面地址。
MAPAY_GATEWAY=https://mzf.mapay.cc/xpay/epay/submit.php
# 码支付订单查询接口地址，用于主动回查支付状态。
MAPAY_API_URL=https://mzf.mapay.cc/xpay/epay/api.php
# 提交给码支付展示的站点名称。
MAPAY_SITENAME=码支付卡密铺
# 可选：码支付后台指定的通道 ID，不需要固定通道可留空。
MAPAY_CHANNEL_ID=
# 可选：码支付设备/场景参数，例如 pc、mobile、alipay；不需要可留空。
MAPAY_DEVICE=

# 订单待付款有效期，单位分钟；超时后 pending 订单会过期并释放预占卡密。
ORDER_TTL_MINUTES=15
# 定时清理接口密钥；请求 /api/cron/expire-orders 时需带 Authorization: Bearer <CRON_SECRET>。
# 留空时定时接口不可调用，但首页/下单/查单/后台访问仍会被动清理过期订单。
CRON_SECRET=

# 管理员访问令牌专用签名密钥，至少 32 位，不得与支付或卡密密钥复用。
ADMIN_SESSION_SECRET=

# 查单密码索引专用 pepper，至少 32 位，配置后不要更换。
ORDER_QUERY_PASSWORD_PEPPER=

# 卡密加密专用密钥，至少 32 位，配置后不要更换，否则旧卡密无法解密。
CARD_SECRET_ENCRYPTION_KEY=

# PostgreSQL 数据库连接信息。
POSTGRES_HOST=192.168.31.80
POSTGRES_PORT=5432
POSTGRES_USER=mazhifu
POSTGRES_PASSWORD=
POSTGRES_DATABASE=mazhifu

# Redis 连接信息（用于 BullMQ 任务队列和生产环境接口限流，生产环境必须配置）。
REDIS_HOST=192.168.31.80
REDIS_PORT=6379
REDIS_PASSWORD=
